# ── Required ────────────────────────────────────────────────
# Supabase Postgres — same database the dashboard uses
DATABASE_URL=postgresql://user:password@host:5432/postgres
# Optional TLS overrides: path to a CA bundle to trust, or set
# DATABASE_SSL_NO_VERIFY=true as a last resort (prefer the CA).
DATABASE_CA_CERT=
DATABASE_SSL_NO_VERIFY=

# ── Encryption (Phase 0) ────────────────────────────────────
# 32-byte master key, hex encoded. Generate: openssl rand -hex 32
# Must match NIRIKSHAKA_MASTER_KEY on the dashboard (Vercel env).
NIRIKSHAKA_MASTER_KEY=

# ── LLM (Phase 1+) ──────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Supabase Realtime mailbox ───────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Notifications (Phase 2+) ────────────────────────────────
WACRM_WEBHOOK_URL=

# ── Dashboard integration ───────────────────────────────────
# Used by gate scripts to enqueue via the dashboard API.
DASHBOARD_URL=http://localhost:3000
# Must match AGENT_SHARED_SECRET on the dashboard. Generate: openssl rand -hex 32
AGENT_SHARED_SECRET=

# ── Worker tuning ───────────────────────────────────────────
WORKER_ID=worker-1
POLL_INTERVAL_MS=2000
HEARTBEAT_INTERVAL_MS=10000
# Tasks stuck in 'claimed' longer than this become claimable again
STALE_CLAIM_SECONDS=300

# ── Runner (Phase 2) ────────────────────────────────────────
# One-time on the box: pnpm exec playwright install chromium
#                      sudo pnpm exec playwright install-deps chromium
RUNNER_HEADLESS=true
# Default LLM-recovery budget per run (payload maxCostUsd overrides)
RUNNER_MAX_COST_USD=1.0
# Failure screenshots: Supabase Storage bucket when SUPABASE_* is set,
# else this local directory.
ARTIFACTS_DIR=./artifacts
SUPABASE_ARTIFACTS_BUCKET=test-artifacts

# ── MCP server (Phase 2) ────────────────────────────────────
# stdio (Claude Code local) | http (Streamable HTTP, x-agent-secret auth)
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8788

# ── Gate 0 (optional) ───────────────────────────────────────
# An ACTIVE project API key; enables the encryption-at-rest check in gate:0.
GATE0_TRACK_API_KEY=
