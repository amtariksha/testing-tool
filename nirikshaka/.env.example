# Existing dashboard env (values live in Vercel / .env.local)
DATABASE_URL=postgresql://user:password@host:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Phase 0: agent layer ────────────────────────────────────
# 32-byte master key, hex encoded. Generate: openssl rand -hex 32
# Must match NIRIKSHAKA_MASTER_KEY in nirikshaka-worker/.env.
NIRIKSHAKA_MASTER_KEY=
# Shared secret for /api/agent/* headless callers (worker gate scripts, MCP).
# Must match AGENT_SHARED_SECRET in nirikshaka-worker/.env.
AGENT_SHARED_SECRET=
